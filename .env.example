# ============================================================
# Laravel AI Core — Environment Configuration
# ============================================================
# 1. Copy this file: cp .env.example .env
# 2. Generate app key: php artisan key:generate
# 3. Configure your database and run: php artisan migrate
# 4. Add your OpenRouter API key for production AI calls
# 5. Install Ollama locally for development: https://ollama.com
# ============================================================

APP_NAME="Laravel AI Core"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8000

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# ============================================================
# Database
# ============================================================
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=laravel_ai_core
DB_USERNAME=
DB_PASSWORD=

# ============================================================
# Session & Cache
# ============================================================
SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local

# ============================================================
# Queue — Redis recommended for production
# ============================================================
QUEUE_CONNECTION=redis
CACHE_STORE=redis

# ============================================================
# Redis
# ============================================================
REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

# ============================================================
# Mail
# ============================================================
MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

# ============================================================
# AI Providers
# ============================================================
# Prism defaults (used internally)
PRISM_DEFAULT_PROVIDER=ollama
PRISM_DEFAULT_MODEL=llama3.2:1b

# OpenRouter API key — get yours at https://openrouter.ai
OPENROUTER_API_KEY=

# ============================================================
# AI Configuration
# ============================================================
# Cache duration for AI responses (seconds)
AI_CACHE_TTL=3600

# Models — local development (Ollama)
AI_TEXT_MODEL=llama3.2:1b
AI_TOOLS_MODEL=llama3.1:8b
AI_EMBEDDINGS_MODEL=nomic-embed-text
AI_AGENT_MODEL=llama3.1:8b

# Providers
AI_DEFAULT_PROVIDER=ollama
AI_PRODUCTION_PROVIDER=openrouter

# Fallback chain — first tried, then second if first fails
AI_FALLBACK_PRIMARY_MODEL=openrouter/free
AI_FALLBACK_SECONDARY_MODEL=llama3.2:1b